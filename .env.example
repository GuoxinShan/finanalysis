# LLM Configuration
OPENAI_API_KEY=your-api-key-here
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen3.5-flash
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4000

# Processing Configuration
CACHE_ENABLED=true
CACHE_DIR=./cache
OUTPUT_DIR=./output

# Extraction Configuration
TEXT_MIN_LENGTH=20
TABLE_AREA_THRESHOLD=0.5
